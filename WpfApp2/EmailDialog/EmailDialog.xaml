<Window x:Class="MarkdownEditorDiploma.EmailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Style="{StaticResource WindowIcon}"
        Title="Отправка по электронной почте" Height="580" Width="600"
        WindowStartupLocation="CenterOwner" Background="#FF1E1E1E"
        ResizeMode="NoResize">

	<Grid Margin="15">
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="120"/>
			<ColumnDefinition Width="*"/>
		</Grid.ColumnDefinitions>

		<TextBlock Grid.Row="0" Grid.Column="0" Text="SMTP сервер:" Foreground="#FFD4D4D4" VerticalAlignment="Center" FontWeight="Bold"/>
		<ComboBox x:Name="SmtpServerCombo" Grid.Row="0" Grid.Column="1" Margin="32,5,10,5" Background="#FF2D2D2D" Foreground="#FF2C2C2C" 
                  IsEditable="True" Padding="5">
			<ComboBoxItem Content="smtp.gmail.com" IsSelected="True"/>
			<ComboBoxItem Content="smtp.mail.ru"/>
			<ComboBoxItem Content="smtp.yandex.ru"/>
			<ComboBoxItem Content="smtp.rambler.ru"/>
			<ComboBoxItem Content="smtp.mail.yahoo.com"/>
			<ComboBoxItem Content="smtp.office365.com"/>
		</ComboBox>

		<TextBlock Grid.Row="1" Grid.Column="0" Text="Порт:" Foreground="#FFD4D4D4" VerticalAlignment="Center" FontWeight="Bold"/>
		<ComboBox x:Name="PortCombo" Grid.Row="1" Grid.Column="1" Margin="32,5,10,5" Background="#FF2D2D2D" Foreground="#FF2C2C2C" 
                  IsEditable="True" Padding="5">
			<ComboBoxItem Content="587" IsSelected="True"/>
			<ComboBoxItem Content="465"/>
			<ComboBoxItem Content="25"/>
		</ComboBox>

		<TextBlock Grid.Row="2" Grid.Column="0" Text="Ваша почта:" Foreground="#FFD4D4D4" VerticalAlignment="Center" FontWeight="Bold"/>
		<TextBox x:Name="YourEmailBox" Grid.Row="2" Grid.Column="1" Margin="32,5,10,5" Background="#FF2D2D2D" Foreground="#FFFFFFFF" Padding="5" FontFamily="Consolas"/>

		<TextBlock Grid.Row="3" Grid.Column="0" Foreground="#FFD4D4D4" VerticalAlignment="Center" FontWeight="Bold" Grid.ColumnSpan="2" Margin="0,0,381,0"><Run Text="Пароль"/><Run Language="ru-ru" Text=" приложения"/><Run Text=":"/></TextBlock>
		<PasswordBox x:Name="PasswordBox" Grid.Row="3" Grid.Column="1" Margin="32,5,10,5" Background="#FF2D2D2D" Foreground="#FFFFFFFF" Padding="5"/>

		<TextBlock Grid.Row="4" Grid.Column="0" Text="Кому:" Foreground="#FFD4D4D4" VerticalAlignment="Center" FontWeight="Bold"/>
		<TextBox x:Name="ToEmailBox" Grid.Row="4" Grid.Column="1" Margin="32,5,10,5" Background="#FF2D2D2D" Foreground="#FFFFFFFF" Padding="5" FontFamily="Consolas"/>

		<TextBlock Grid.Row="5" Grid.Column="0" Text="Тема:" Foreground="#FFD4D4D4" VerticalAlignment="Center" FontWeight="Bold"/>
		<TextBox x:Name="SubjectBox" Grid.Row="5" Grid.Column="1" Margin="32,5,10,5" Background="#FF2D2D2D" Foreground="#FFFFFFFF" Padding="5" 
                 Text="📄 Документ из Doctus"/>

		<TextBlock Grid.Row="6" Grid.Column="0" Text="Формат вложения:" Foreground="#FFD4D4D4" VerticalAlignment="Center" FontWeight="Bold"/>
		<ComboBox x:Name="FormatCombo" Grid.Row="6" Grid.Column="1" Margin="32,5,10,5" Background="#FF2D2D2D" Foreground="#FF2C2C2C" 
                  SelectedIndex="0" Padding="5">
			<ComboBoxItem Content="📝 Markdown (.md)"/>
			<ComboBoxItem Content="🌐 HTML (.html)"/>
		</ComboBox>

		<TextBlock Grid.Row="7" Grid.Column="0" Text="Сообщение:" Foreground="#FFD4D4D4" VerticalAlignment="Top" Margin="0,5" FontWeight="Bold"/>
		<TextBox x:Name="MessageBox" Grid.Row="7" Grid.Column="1" Height="80" TextWrapping="Wrap" 
                 Background="#FF2D2D2D" Foreground="#FFFFFFFF" Padding="5" AcceptsReturn="True" 
                 Text="Отправляю документ, созданный в Doctus — современном Markdown-редакторе." Margin="32,0,10,35" Grid.RowSpan="2"/>

		<TextBlock x:Name="StatusText" Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" 
                   Foreground="#FF6FCF97" Margin="0,10" TextAlignment="Center" FontSize="11"/>

		<Border Grid.Row="9" Grid.Column="0" Grid.ColumnSpan="2" Height="1" Background="#FF3E3E42" Margin="0,5"/>

		<StackPanel Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10">
			<Button x:Name="SendButton" Content="✉️ Отправить" Click="Send_Click" Width="110" Margin="0,0,10,0"
                    Background="#FF853953" Foreground="#FFFFFFFF" Padding="8,5" Cursor="Hand" FontWeight="Bold"/>
			<Button x:Name="CancelButton" Content="❌ Отмена" Click="Cancel_Click" Width="90"
                    Background="#FF3E3E42" Foreground="#FFFFFFFF" Padding="8,5" Cursor="Hand"/>
		</StackPanel>
	</Grid>
</Window>