    <Window x:Class="MarkdownEditorDiploma.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Doctus" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#FF1E1E1E">

    <DockPanel>
        <!-- Область с меню-баром -->
        <Menu DockPanel.Dock="Top" Background="#FF2D2D2D" Foreground="#FFFFFFFF">
            <Menu.Resources>

                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#D02752"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="#FFFFFFFF"/>
                <SolidColorBrush x:Key="{x:Static SystemColors.MenuHighlightBrushKey}" Color="#D02752"/>
                
                <Style TargetType="MenuItem">
                    <Setter Property="Background" Value="#FF2D2D2D"/>
                    <Setter Property="Foreground" Value="#FFFFFFFF"/>
                    <Setter Property="Padding" Value="10,6"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="FontWeight" Value="Medium"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#D02752"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter Property="Background" Value="#FF3C3C3C"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="MenuItem" x:Key="SubMenuItemStyle">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#091413"/>
                    <Setter Property="Padding" Value="30,8,20,8"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#D02752"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>

                <Style TargetType="MenuItem" x:Key="ViewMenuItemStyle">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#091413"/>
                    <Setter Property="Padding" Value="30,8,20,8"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#D02752"/>
                            <Setter Property="Foreground" Value="#FFFFFFFF"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
                
                <Style TargetType="Separator">
                    <Setter Property="Background" Value="#FF3E3E42"/>
                    <Setter Property="Height" Value="1"/>
                    <Setter Property="Margin" Value="8,4"/>
                </Style>

                <Style TargetType="ContextMenu">
                    <Setter Property="Background" Value="#FF252525"/>
                    <Setter Property="BorderBrush" Value="#FF3E3E42"/>
                    <Setter Property="BorderThickness" Value="1"/>
                </Style>
            </Menu.Resources>

            <!-- Меню для работы с файлами -->
            <MenuItem Header="_Файл">
                <MenuItem Header="Новый" Click="NewFile_Click" InputGestureText="Ctrl+N" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Открыть MD..." Click="OpenMd_Click" InputGestureText="Ctrl+O" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Открыть HTML..." Click="OpenHtml_Click" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Сохранить" Click="Save_Click" InputGestureText="Ctrl+S" Style="{StaticResource SubMenuItemStyle}">
                </MenuItem>
            <MenuItem Header="Сохранить как MD..." Click="SaveAsMd_Click" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Сохранить как HTML..." Click="SaveAsHtml_Click" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Сохранить как PDF..." Click="SaveAsPdf_Click" InputGestureText="Ctrl+Shift+P" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Выход" Click="Exit_Click" InputGestureText="Alt+F4" Style="{StaticResource SubMenuItemStyle}"/>
            </MenuItem>

            <!-- Меню для изменения отображения -->
            <MenuItem Header="_Вид">
                <MenuItem Header="Только редактор" Click="ViewEditorOnly_Click" InputGestureText="Ctrl+E" Style="{StaticResource ViewMenuItemStyle}"/>
                <MenuItem Header="Только просмотр" Click="ViewPreviewOnly_Click" InputGestureText="Ctrl+P" Style="{StaticResource ViewMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Вместе" Click="ViewBoth_Click" InputGestureText="Ctrl+B" Style="{StaticResource ViewMenuItemStyle}">
                </MenuItem>
            </MenuItem>

            <!-- Меню для тэгов MarkDown -->
            <MenuItem Header="_Тэги">
                <MenuItem Header="Жирный" Click="TagBold_Click" InputGestureText="Ctrl+Shift+B" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Курсив" Click="TagItalic_Click" InputGestureText="Ctrl+Shift+I" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Подчёркнутый" Click="TagUnderline_Click" InputGestureText="Ctrl+Shift+U" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Зачёркнутый" Click="TagStrikethrough_Click" InputGestureText="Ctrl+Shift+S" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Блок кода" Click="TagCodeBlock_Click" InputGestureText="Ctrl+Shift+С" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Код" Click="TagCode_Click" InputGestureText="Ctrl+Shift+X" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Маркированный список" Click="TagBulletList_Click" InputGestureText="Ctrl+Shift+L" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Нумерованный список" Click="TagNumberedList_Click" InputGestureText="Ctrl+Shift+N" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Таблица (3x3)" Click="TagTable_Click" InputGestureText="Ctrl+Shift+T" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Ограничительная линия" Click="TagLine_Click" InputGestureText="Ctrl+Shift+H" Style="{StaticResource SubMenuItemStyle}"/>
            </MenuItem>

            <MenuItem Header="Стили">
                <MenuItem Header="Загрузить CSS-файл..." Click="LoadCssFile_Click" InputGestureText="Ctrl+Shift+O" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Редактировать текущий стиль" Click="EditCurrentStyle_Click" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Сбросить на стандартный" Click="ResetToDefaultStyle_Click" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Перезагрузить стиль" Click="ReloadPreviewStyles_Click" InputGestureText="F5" Style="{StaticResource SubMenuItemStyle}"/>
                </MenuItem>


            <MenuItem Header="_Отправить">
                <MenuItem Header="Экспортировать как MD..." Click="ExportAsMd_Click" InputGestureText="Ctrl+Shift+M" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Экспортировать как HTML..." Click="ExportAsHtml_Click" InputGestureText="Ctrl+Shift+H" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Экспортировать как PDF..." Click="ExportAsPdf_Click" InputGestureText="Ctrl+Shift+F" Style="{StaticResource SubMenuItemStyle}"/>
                <Separator/>
                <MenuItem Header="Отправить по почте..." Click="SendByEmail_Click" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Копировать в буфер (HTML)" Click="CopyHtmlToClipboard_Click" Style="{StaticResource SubMenuItemStyle}"/>
                <MenuItem Header="Копировать в буфер (Markdown)" Click="CopyMdToClipboard_Click" Style="{StaticResource SubMenuItemStyle}"/>
            </MenuItem>

            <MenuItem Header="_Справка">
                <MenuItem Header="О программе" Click="About_Click" Style="{StaticResource SubMenuItemStyle}"/>
            </MenuItem>
            
        </Menu>

        <!-- Основная область редактора и предпросмотра -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="6"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Левая панель: редактор Markdown -->
            <Border Grid.Row="0" Grid.Column="0" 
                    Background="#FF1E1E1E" 
                    CornerRadius="6" 
                    BorderBrush="#FF3E3E42" 
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF252525" CornerRadius="6,6,0,0" Padding="12,8">
                        <TextBlock Text="РЕДАКТОР" 
                                   Foreground="#FFFFFFFF" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <TextBox x:Name="Editor" Grid.Row="1"
                             TextWrapping="Wrap" 
                             AcceptsReturn="True" 
                             AcceptsTab="True" 
                             VerticalScrollBarVisibility="Auto" 
                             HorizontalScrollBarVisibility="Disabled"
                             FontFamily="Consolas" 
                             FontSize="13"
                             TextChanged="Editor_TextChanged" 
                             Foreground="#FFFFFFFF"
                             Background="#FF1E1E1E"
                             BorderThickness="0"
                             CaretBrush="#FFFFFFFF"
                             Padding="12"
                             SelectionBrush="#FF0E639C"
                             SelectionOpacity="0.7"/>
                </Grid>
            </Border>

            <!-- Разделитель -->
            <GridSplitter Grid.Row="0" Grid.Column="1" 
                          HorizontalAlignment="Stretch" 
                          Background="#FF3E3E42" 
                          Width="6"
                          ResizeDirection="Columns"/>

            <!-- Правая панель: предпросмотр -->
            <Border Grid.Row="0" Grid.Column="2" 
                    Background="#FF1E1E1E" 
                    CornerRadius="6" 
                    BorderBrush="#FF3E3E42" 
                    BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FF252525" CornerRadius="6,6,0,0" Padding="12,8">
                        <TextBlock Text="ПРЕДПРОСМОТР" 
                                   Foreground="#FFFFFFFF" 
                                   FontSize="11" 
                                   FontWeight="SemiBold"
                                   FontFamily="Segoe UI"/>
                    </Border>

                    <Border Grid.Row="1" Background="#FF1E1E1E" Margin="0">
                        <wpf:WebView2 x:Name="Preview"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>